{
  "autoSave": false,
  "autoSaveDelay": 5000,
  "titleBarStyle": "custom",
  "openFilesInNewWindow": false,
  "openFolderInNewWindow": false,
  "zoom": 1.0,
  "hideScrollbar": false,
  "wordWrapInToc": false,
  "fileSortBy": "created",
