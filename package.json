{
  "name": "marqen-monorepo",
  "version": "0.20.3-dev",
  "description": "Marqen monorepo root",
  "private": true,
  "homepage": "https://github.com/marqen/marqen",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "postinstall": "tsx scripts/postinstall.ts",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "minify-locales": "tsx scripts/minify-locales.ts",
    "rebuild-native": "pnpm --filter marqen rebuild-native",
    "start": "pnpm --filter marqen start",
    "dev": "pnpm --filter marqen dev",
    "build": "pnpm --filter marqen build",
    "build:unpack": "pnpm --filter marqen build:unpack",
    "build:win": "pnpm --filter marqen build:win",
    "build:win:x64": "pnpm --filter marqen build:win:x64",
    "build:win:arm64": "pnpm --filter marqen build:win:arm64",
    "build:mac": "pnpm --filter marqen build:mac",
    "build:mac:x64": "pnpm --filter marqen build:mac:x64",
    "build:mac:arm64": "pnpm --filter marqen build:mac:arm64",
    "build:linux": "pnpm --filter marqen build:linux",
    "perf:inspect": "pnpm --filter marqen perf:inspect",
    "perf:inspect-brk": "pnpm --filter marqen perf:inspect-brk",
    "test": "pnpm --filter marqen test",
    "test:unit": "pnpm --filter marqen test:unit",
    "test:e2e": "pnpm --filter marqen test:e2e",
    "typecheck": "pnpm --filter marqen typecheck",
    "typecheck:watch": "pnpm --filter marqen typecheck:watch",
    "check": "pnpm lint && pnpm typecheck",
    "gen-third-party": "tsx scripts/generateThirdPartyLicense.ts",
    "validate-licenses": "tsx scripts/validateLicenses.ts"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "electron": "^42.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-vue": "^10.9.1",
    "license-checker": "^25.0.1",
    "neostandard": "^0.13.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.59.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
